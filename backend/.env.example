# Primary POI provider — get a free key at https://myprojects.geoapify.com/
GEOAPIFY_API_KEY=

# Fallbacks (tried if Geoapify fails)
OVERPASS_URL=https://overpass.kumi.systems/api/interpreter,https://overpass-api.de/api/interpreter,https://overpass.openstreetmap.ru/api/interpreter

# Force demo mode (serves baked-in fixtures, no network required)
DEMO_MODE=false

# Caching (optional — runs without Redis, just slower)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# Misc
NOMINATIM_USER_AGENT=optipoint-dev
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=INFO
